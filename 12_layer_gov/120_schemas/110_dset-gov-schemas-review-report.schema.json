{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/anatoly-m-maslennikov/dset-specs-loops-framework/main/.dset/000_dset_methodology/02_gov/schemas/review-report.schema.json",
  "title": "DSET external review report frontmatter",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "artifact_subtype",
    "artifact_id",
    "packet_id",
    "priority",
    "reviewer",
    "llm_session_ids",
    "reviewed_commit",
    "reviewed_inputs",
    "method",
    "observed_at",
    "limitations",
    "findings"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "artifact_type": {
      "const": "evidence_record"
    },
    "artifact_subtype": {
      "const": "review_report"
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*-EVIDENCE-RECORD-[0-9]{3,}$"
    },
    "packet_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*-REVIEW-PACKET-[0-9]{3,}$"
    },
    "priority": {
      "type": "string",
      "minLength": 1
    },
    "reviewer": {
      "type": "object",
      "required": [
        "identity",
        "host",
        "model",
        "tool_version"
      ],
      "additionalProperties": false,
      "properties": {
        "identity": {
          "type": "string",
          "minLength": 1
        },
        "host": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "tool_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "llm_session_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_-]*:[A-Za-z0-9._:-]+$"
      }
    },
    "reviewed_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "reviewed_inputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/input"
      }
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "findings": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/finding"
      }
    }
  },
  "$defs": {
    "input": {
      "type": "object",
      "required": [
        "carrier",
        "sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "carrier": {
          "type": "string",
          "pattern": "^[^/\\\\]+$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "finding": {
      "type": "object",
      "required": [
        "id",
        "priority",
        "evidence",
        "confidence",
        "impact",
        "proposed_disposition"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9]*-REVIEW-FINDING-[0-9]{3,}$"
        },
        "priority": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "impact": {
          "type": "string",
          "minLength": 1
        },
        "proposed_disposition": {
          "enum": [
            "reject",
            "defer",
            "route_problem",
            "route_question",
            "route_decision",
            "route_change",
            "route_evergreen",
            "route_proof"
          ]
        }
      }
    }
  }
}
