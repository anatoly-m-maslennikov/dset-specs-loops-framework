{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/anatoly-m-maslennikov/dset-specs-loops-framework/main/.dset/000_dset_methodology/02_gov/schemas/compilation.schema.json",
  "title": "DSET active authority compilation index",
  "type": "object",
  "required": [
    "schema_version",
    "records"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "records": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/record"
      }
    }
  },
  "$defs": {
    "identity": {
      "type": "object",
      "required": [
        "carrier",
        "sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "carrier": {
          "type": "string",
          "pattern": "^[^/\\\\]+$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "fragment": {
      "type": "object",
      "required": [
        "kind",
        "line",
        "sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "section",
            "table-row",
            "labeled-block"
          ]
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "projection": {
      "type": "object",
      "required": [
        "carrier",
        "sha256",
        "fragments"
      ],
      "additionalProperties": false,
      "properties": {
        "carrier": {
          "type": "string",
          "pattern": "^[^/\\\\]+$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "fragments": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/fragment"
          }
        }
      }
    },
    "record": {
      "type": "object",
      "required": [
        "id",
        "source",
        "projections"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$"
        },
        "source": {
          "$ref": "#/$defs/identity"
        },
        "projections": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/projection"
          }
        }
      }
    }
  }
}
