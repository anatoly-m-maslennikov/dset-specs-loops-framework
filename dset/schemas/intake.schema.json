{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/anatoly-m-maslennikov/dset-specs-loops-framework/main/dset/schemas/intake.schema.json",
  "title": "DSET project intake registry",
  "type": "object",
  "required": ["schema_version", "scope_mode", "scopes", "items"],
  "properties": {
    "schema_version": {"const": 1.0},
    "scope_mode": {"const": "multi-scope"},
    "scopes": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/scope"}
    },
    "items": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/item"}
    }
  },
  "allOf": [
    {"properties": {"scopes": {"contains": {"properties": {"id_segment": {"const": "META"}}, "required": ["id_segment"]}}}},
    {"properties": {"scopes": {"contains": {"properties": {"id_segment": {"const": "GOV"}}, "required": ["id_segment"]}}}},
    {"properties": {"scopes": {"contains": {"properties": {"id_segment": {"const": "TOOL"}}, "required": ["id_segment"]}}}},
    {"properties": {"scopes": {"contains": {"properties": {"id_segment": {"const": "SKILL"}}, "required": ["id_segment"]}}}},
    {"properties": {"scopes": {"contains": {"properties": {"id_segment": {"const": "OPS"}}, "required": ["id_segment"]}}}}
  ],
  "$defs": {
    "trace_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*-(?:REQUIREMENT|SCENARIO|INVARIANT|TEST|EVAL|TASK|PROBLEM|OPPORTUNITY|QUESTION|DECISION|CONTRACT|STORY|OUTCOME)(?:-(?:META|GOV|TOOL|SKILL|OPS))?-[0-9]{3,}$"},
    "scope": {
      "type": "object",
      "required": ["id", "id_segment", "kind", "name"],
      "properties": {
        "id": {"enum": ["meta", "gov", "tool", "skill", "ops"]},
        "id_segment": {"enum": ["META", "GOV", "TOOL", "SKILL", "OPS"]},
        "kind": {"const": "layer"},
        "name": {"type": "string", "minLength": 1},
        "path": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "item": {
      "type": "object",
      "required": ["id", "scope", "type", "status", "title", "statement", "owner_change", "decision"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*-(?:PROBLEM|OPPORTUNITY|QUESTION)(?:-(?:META|GOV|TOOL|SKILL|OPS))?-[0-9]{3,}$"},
        "scope": {"enum": ["meta", "gov", "tool", "skill", "ops"]},
        "type": {"enum": ["problem", "opportunity", "question"]},
        "status": {"enum": ["open", "accepted", "resolved", "closed"]},
        "title": {"type": "string", "minLength": 1},
        "statement": {"type": "string", "minLength": 1},
        "owner_change": {"oneOf": [{"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}, {"const": "pending"}, {"type": "null"}]},
        "decision": {"oneOf": [{"type": "string", "pattern": "^[A-Z][A-Z0-9]*-DECISION(?:-(?:META|GOV|TOOL|SKILL|OPS))?-[0-9]{3,}$"}, {"const": "pending"}, {"type": "null"}]},
        "external_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
