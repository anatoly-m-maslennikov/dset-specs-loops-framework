{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/anatoly-m-maslennikov/dset-specs-loops-framework/main/dset/schemas/skill-run.schema.json",
  "title": "DSET local skill-run record",
  "type": "object",
  "required": ["schema_version", "run_id", "started_at", "status", "persistence", "scope", "skill_id", "workflow_id", "mode_id", "ruleset_identity", "parameters", "outputs", "diagnostics", "next_signals", "budget"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"$ref": "#/$defs/id"},
    "parent_run_id": {"oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
    "started_at": {"type": "string", "format": "date-time", "maxLength": 40},
    "finished_at": {"oneOf": [{"type": "string", "format": "date-time", "maxLength": 40}, {"type": "null"}]},
    "status": {"enum": ["running", "succeeded", "failed", "stopped", "interrupted"]},
    "persistence": {"enum": ["persisted", "unavailable"]},
    "scope": {
      "type": "object",
      "required": ["repository", "project", "package", "feature", "change"],
      "properties": {
        "repository": {"$ref": "#/$defs/nullable_text"},
        "project": {"$ref": "#/$defs/nullable_text"},
        "package": {"$ref": "#/$defs/nullable_text"},
        "feature": {"$ref": "#/$defs/nullable_text"},
        "change": {"$ref": "#/$defs/nullable_text"}
      },
      "additionalProperties": false
    },
    "skill_id": {"$ref": "#/$defs/nullable_text"},
    "workflow_id": {"$ref": "#/$defs/nullable_text"},
    "mode_id": {"$ref": "#/$defs/nullable_text"},
    "ruleset_identity": {"$ref": "#/$defs/nullable_text"},
    "parameters": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "required": ["name", "representation", "value"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]{0,63}$"},
          "representation": {"enum": ["category", "sha256", "redacted"]},
          "value": {"type": "string", "maxLength": 256}
        },
        "additionalProperties": false
      }
    },
    "outputs": {"type": "array", "maxItems": 32, "items": {"type": "string", "maxLength": 512}},
    "diagnostics": {"type": "array", "maxItems": 32, "items": {"type": "string", "maxLength": 128}},
    "next_signals": {"type": "array", "maxItems": 16, "items": {"type": "string", "maxLength": 128}},
    "budget": {
      "type": "object",
      "required": ["profile", "requested_model", "requested_effort", "effective_model", "effective_effort", "attestation", "planned_subagents", "actual_subagents", "planned_rounds", "actual_rounds", "deviations"],
      "properties": {
        "profile": {"enum": ["low", "medium", "high"]},
        "requested_model": {"$ref": "#/$defs/nullable_text"},
        "requested_effort": {"$ref": "#/$defs/nullable_text"},
        "effective_model": {"$ref": "#/$defs/nullable_text"},
        "effective_effort": {"$ref": "#/$defs/nullable_text"},
        "attestation": {"enum": ["confirmed", "runtime-default-unverified", "unsupported"]},
        "planned_subagents": {"type": "integer", "minimum": 0, "maximum": 6},
        "actual_subagents": {"type": "integer", "minimum": 0, "maximum": 6},
        "planned_rounds": {"type": "integer", "minimum": 0, "maximum": 3},
        "actual_rounds": {"type": "integer", "minimum": 0, "maximum": 3},
        "deviations": {"type": "array", "maxItems": 8, "items": {"type": "string", "maxLength": 256}}
      },
      "additionalProperties": false
    },
    "usage": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "properties": {
            "input_tokens": {"type": "integer", "minimum": 0},
            "output_tokens": {"type": "integer", "minimum": 0},
            "currency": {"type": "string", "maxLength": 8},
            "cost": {"type": "number", "minimum": 0}
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "nullable_text": {"oneOf": [{"type": "string", "maxLength": 256}, {"type": "null"}]}
  },
  "additionalProperties": false
}
