{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/anatoly-m-maslennikov/dset-specs-loops-framework/main/dset/scopes/gov/schemas/conflict-result.schema.json",
  "title": "DSET governed conflict result",
  "type": "object",
  "required": ["schema_version", "left", "right", "context", "profile", "input_sha256", "resolution_basis_sha256", "conflict_atom_required", "selected_id", "resolution_event_required", "stale_when", "conflict_class", "disposition"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "left": {"type": "object"},
    "right": {"type": "object"},
    "context": {"type": "object"},
    "profile": {"type": "string", "minLength": 1},
    "input_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "resolution_basis_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "conflict_atom_required": {"type": "boolean"},
    "selected_id": {"type": ["string", "null"]},
    "resolution_event_required": {"type": "boolean"},
    "stale_when": {"type": "string", "minLength": 1},
    "conflict_class": {"enum": ["absorption", "source_projection_drift", "not_a_conflict", "assurance_change", "implementation_nonconformance", "implementation_ownership", "evidence_adjudication", "generated_staleness", "projection_ownership", "immutable_external_authority", "unsatisfiable_immutable_authority", "nonselectable_authority", "selectable_policy"]},
    "disposition": {"enum": ["absorbing_atom_governs", "recompile_projection", "no_conflict", "update_assurance_and_relying_gate", "route_problem_defect", "follow_owner_or_stop", "apply_proof_plan_or_stop", "refresh_derived_view", "route_source_conflict_or_recompile", "declare_source_projection_relation_or_stop", "external_authority_governs", "stop_for_external_resolution", "stop_for_decision", "selected_by_precedence", "stop_on_equal_unknown_or_incomparable_priority", "selected_by_priority"]}
  },
  "additionalProperties": false
}
