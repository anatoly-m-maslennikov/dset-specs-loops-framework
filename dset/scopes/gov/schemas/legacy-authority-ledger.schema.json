{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/anatoly-m-maslennikov/dset-specs-loops-framework/main/dset/scopes/gov/schemas/legacy-authority-ledger.schema.json",
  "title": "DSET legacy Decision authority ledger",
  "type": "object",
  "required": ["schema_version", "records"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["semantic_id", "type", "subtype", "fragments"],
        "properties": {
          "semantic_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$"},
          "type": {"const": "decision"},
          "subtype": {"enum": ["none", "requirement", "constraint", "contract", "user_story", "outcome", "scenario", "invariant"]},
          "fragments": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["path", "selector", "sha256"],
              "properties": {
                "path": {"type": "string", "minLength": 1},
                "selector": {"type": "string", "minLength": 1},
                "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
