{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/anatoly-m-maslennikov/dset-specs-loops-framework/main/dset/scopes/gov/schemas/artifact-types.schema.json",
  "title": "DSET artifact-type registry",
  "type": "object",
  "required": [
    "schema_version",
    "profile",
    "classification",
    "exclusions",
    "legacy_evidence_paths",
    "legacy_structured",
    "artifact_types",
    "path_rules"
  ],
  "properties": {
    "schema_version": {"const": 1.0},
    "profile": {"const": "documentation-v1"},
    "classification": {
      "type": "object",
      "required": ["unclassified", "multiple_matches", "direct_metadata_fields"],
      "properties": {
        "unclassified": {"const": "error"},
        "multiple_matches": {"const": "error"},
        "direct_metadata_fields": {
          "type": "object",
          "required": ["type", "subtype"],
          "properties": {
            "type": {"const": "artifact_type"},
            "subtype": {"const": "artifact_subtype"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "artifact_types": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/artifact_type"}
    },
    "path_rules": {
      "type": "array",
      "items": {"$ref": "#/$defs/path_rule"}
    },
    "exclusions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/exclusion"}
    },
    "legacy_evidence_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[^*?\\[\\]]+/proofs/[^*?\\[\\]]+\\.md$"
      }
    },
    "legacy_structured": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/legacy_structured"}
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "artifact_type": {
      "type": "object",
      "required": ["id", "primary_question", "allow_empty_subtype", "subtypes"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "primary_question": {"type": "string", "minLength": 1},
        "allow_empty_subtype": {"type": "boolean"},
        "subtypes": {
          "type": "array",
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "path_rule": {
      "type": "object",
      "required": ["pattern", "artifact_type"],
      "properties": {
        "pattern": {"type": "string", "minLength": 1},
        "artifact_type": {"$ref": "#/$defs/id"},
        "artifact_subtype": {"$ref": "#/$defs/id"}
      },
      "additionalProperties": false
    },
    "legacy_structured": {
      "type": "object",
      "required": [
        "path",
        "sha256",
        "current_owner",
        "artifact_type",
        "retained_for"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.?/)(?!.*[*?\\[\\]])[^\\\\]+\\.ya?ml$"
        },
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "current_owner": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.?/)(?!.*[*?\\[\\]])[^\\\\]+\\.toml$"
        },
        "artifact_type": {"$ref": "#/$defs/id"},
        "artifact_subtype": {"$ref": "#/$defs/id"},
        "retained_for": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/retention_identity"}
        }
      },
      "additionalProperties": false
    },
    "retention_identity": {
      "type": "object",
      "required": ["reason"],
      "properties": {
        "semantic_id": {"type": "string", "minLength": 1},
        "carrier_path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.?/)(?!.*[*?\\[\\]])[^\\\\]+\\.md$"
        },
        "reason": {"type": "string", "minLength": 1}
      },
      "oneOf": [
        {"required": ["semantic_id"], "not": {"required": ["carrier_path"]}},
        {"required": ["carrier_path"], "not": {"required": ["semantic_id"]}}
      ],
      "additionalProperties": false
    },
    "exclusion": {
      "type": "object",
      "required": ["pattern", "rationale"],
      "properties": {
        "pattern": {"type": "string", "minLength": 1},
        "rationale": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
