{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/anatoly-m-maslennikov/dset-specs-loops-framework/main/dset/scopes/gov/schemas/compilation.schema.json",
  "title": "DSET active authority compilation index",
  "type": "object",
  "required": ["schema_version", "records"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "records": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/record"}}
  },
  "$defs": {
    "identity": {"type": "object", "required": ["path", "sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}, "additionalProperties": false},
    "fragment": {"type": "object", "required": ["kind", "line", "sha256"], "properties": {"kind": {"enum": ["section", "table-row", "labeled-block"]}, "line": {"type": "integer", "minimum": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}, "additionalProperties": false},
    "projection": {"type": "object", "required": ["path", "sha256", "fragments"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "fragments": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/fragment"}}}, "additionalProperties": false},
    "record": {"type": "object", "required": ["id", "source", "projections"], "properties": {"id": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$"}, "source": {"$ref": "#/$defs/identity"}, "projections": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/projection"}}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
