{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/anatoly-m-maslennikov/dset-specs-loops-framework/main/.dset/layer_2_gov/schemas/provenance.schema.json",
  "title": "DSET provenance manifest",
  "type": "object",
  "required": ["schema_version", "project_license", "sources"],
  "properties": {
    "schema_version": {"const": 1.0},
    "project_license": {"type": "string", "minLength": 1},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "repository", "revision", "license", "license_file", "use"],
        "properties": {
          "id": {"type": "string"},
          "repository": {"type": "string", "format": "uri"},
          "revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
          "license": {"type": "string"},
          "license_file": {"type": "string"},
          "use": {"type": "string"},
          "mappings": {
            "type": "array",
            "items": {"$ref": "#/$defs/mapping"}
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "mapping": {
      "type": "object",
      "required": ["pattern", "source", "source_lines", "dset_surface", "disposition", "adaptation_scope", "exclusions"],
      "properties": {
        "pattern": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "source_lines": {"type": "string", "pattern": "^[0-9,-]+$"},
        "dset_surface": {"type": "string", "minLength": 1},
        "disposition": {"enum": ["adopted", "adapted", "rejected"]},
        "adaptation_scope": {"type": "string", "minLength": 1},
        "exclusions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
