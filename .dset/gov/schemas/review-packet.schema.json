{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/anatoly-m-maslennikov/dset-specs-loops-framework/main/.dset/gov/schemas/review-packet.schema.json",
  "title": "DSET external review packet frontmatter",
  "type": "object",
  "required": ["schema_version", "artifact_type", "artifact_id", "packet_id", "repository", "commit", "scope", "criteria", "reviewed_inputs", "resolved_rules", "allowed_effects"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_type": {"const": "plan"},
    "artifact_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*-PLAN-[0-9]{3,}$"},
    "packet_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*-REVIEW-PACKET-[0-9]{3,}$"},
    "repository": {"type": "string", "minLength": 1},
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "scope": {"type": "string", "minLength": 1},
    "criteria": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "reviewed_inputs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/input"}},
    "resolved_rules": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/rule"}},
    "allowed_effects": {"const": ["read_only_report"]}
  },
  "$defs": {
    "input": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "rule": {
      "type": "object",
      "required": ["id", "path", "sha256"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$"},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
